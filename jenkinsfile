pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                bat 'gradlew.bat build'
            }
        }

        stage('Prepare Docs') {
            steps {
                bat 'gradlew.bat prepareDocs'
            }
        }
    }
}
